# Comma-separated frontend origin(s) allowed by CORS.
# Local Vite default:
ALLOWED_ORIGIN=http://localhost:5173
# After deploying frontend to Vercel, set e.g.:
# ALLOWED_ORIGIN=https://your-app.vercel.app

# Cosine similarity threshold for a positive match (0–1). Default 0.6.
MATCH_THRESHOLD=0.6

# SQLite database file path (created automatically on first run).
SQLITE_PATH=./campus_access.db

# Admin console PIN (required to open /admin and call admin APIs).
ADMIN_PIN=0852

# Port is read by the process manager / uvicorn, not by FastAPI config.
# Local:
#   PORT=8000 uvicorn main:app --host 0.0.0.0 --port $PORT
# Render sets PORT automatically.
PORT=8000
