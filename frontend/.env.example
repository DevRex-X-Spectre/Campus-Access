# Backend base URL — no trailing slash.
# Local FastAPI default:
VITE_API_URL=http://localhost:8000

# After deploying the backend to Render, set e.g.:
# VITE_API_URL=https://your-service.onrender.com

# Optional: face-api.js TinyFaceDetector model base path.
# Default uses files under /models (see README for download steps).
# VITE_FACE_MODEL_URL=/models
